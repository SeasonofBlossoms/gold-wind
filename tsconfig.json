{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "react-jsx",
    "module": "esnext",
    "rootDir": ".",
    "baseUrl": "./",
    "types": [],
    "allowJs": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "moduleResolution": "node"
  },
  "include": [
    "components/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}